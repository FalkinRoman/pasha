NODE_ENV=development
PORT=3001
API_PREFIX=api

DATABASE_URL=postgresql://stopkek:stopkek@localhost:5434/stopkek
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# SMS.ru — входящий звонок + 4 цифры: https://sms.ru/api/code_call
SMSRU_API_ID=

# Без SMSRU_API_ID — mock: код из MOCK_CALL_CODES
MOCK_CALL_CODES=1234
CALL_CODE_TTL_SEC=300
CALL_REQUEST_COOLDOWN_SEC=15

# YooKassa — https://yookassa.ru
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=stopkek://wallet/topup/success
WALLET_MOCK_TOPUP=true

# Админы (npm run admin:seed) — всегда stopkeksprt@mail.ru + опционально ADMIN_EMAIL
ADMIN_EMAIL=stopkeksprt@mail.ru
ADMIN_PASSWORD=
ADMIN_NAME=Админ и поддержка
SUPPORT_EMAIL=stopkeksprt@mail.ru

# Сброс пароля админки — Mail.ru SMTP
# 1) Войти в stopkeksprt@mail.ru на mail.ru
# 2) Настройки → Все настройки → Безопасность
# 3) «Пароли для внешних приложений» → Создать → имя «stopkek API»
# 4) Скопировать пароль (показывается один раз!) → SMTP_PASS
# Прямая ссылка: https://account.mail.ru/user/2-stepauth/passwords/
ADMIN_APP_URL=http://localhost:5173
SMTP_HOST=smtp.mail.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=stopkeksprt@mail.ru
SMTP_PASS=
SMTP_FROM=stopkek Admin <stopkeksprt@mail.ru>

# Верификация паспорта: автоподтверждение через N минут без ответа админа
IDENTITY_AUTO_APPROVE_MIN=5
