NODE_ENV=development
PORT=3001
API_PREFIX=api

DATABASE_URL=postgresql://stopkek:stopkek@localhost:5434/stopkek
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# SMS.ru — входящий звонок + 4 цифры: https://sms.ru/api/code_call
SMSRU_API_ID=

# Без SMSRU_API_ID — mock: код из MOCK_CALL_CODES
MOCK_CALL_CODES=1234
CALL_CODE_TTL_SEC=300
CALL_REQUEST_COOLDOWN_SEC=15

# YooKassa — https://yookassa.ru
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=stopkek://wallet/topup/success
WALLET_MOCK_TOPUP=true
