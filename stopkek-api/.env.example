NODE_ENV=development
PORT=3001
API_PREFIX=api

DATABASE_URL=postgresql://stopkek:stopkek@localhost:5434/stopkek
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production-min-32-chars
# Отдельный секрет для админки (рекомендуется в prod)
JWT_ADMIN_SECRET=
JWT_ADMIN_TTL=12h
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# CORS: через запятую (админка + expo web). Пусто в dev = *
# CORS_ORIGINS=http://localhost:5173,http://localhost:8081

# SMS.ru — звонок (code_call) + callcheck + SMS (sms/send): https://sms.ru
SMSRU_API_ID=
# Имя отправителя SMS (буквенное, одобренное операторами в SMS.ru → Отправители)
SMSRU_SENDER_ID=stopkek

# Windows-подложка (X-Kiosk-Key) + QR payload
KIOSK_API_KEY=stopkek-kiosk-prod-2026
PUBLIC_API_URL=http://stopkek.site/api

# Без SMSRU_API_ID — mock: код из MOCK_CALL_CODES
MOCK_CALL_CODES=1234
CALL_CODE_TTL_SEC=300
CALLCHECK_TTL_SEC=300
CALL_REQUEST_COOLDOWN_SEC=15

# Apple App Review — фиксированный вход без звонка (prod: задать в deploy/.env.prod)
REVIEW_LOGIN_PHONE=+79001234567
REVIEW_LOGIN_CODE=1234

# YooKassa — https://yookassa.ru
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=stopkek://wallet/topup/success
WALLET_MOCK_TOPUP=true
# Минимум пополнения (₽), по умолчанию 100
WALLET_TOPUP_MIN_RUB=100
WALLET_TOPUP_MIN_MOCK_RUB=100

# Тест-бронь 16 мин — только dev/staging (в prod не включать)
# ALLOW_TEST_BOOKINGS=1

# Единственный админ (npm run admin:seed)
ADMIN_EMAIL=stopkeksprt@yandex.ru
ADMIN_PASSWORD=
ADMIN_NAME=Админ и поддержка
SUPPORT_EMAIL=stopkeksprt@yandex.ru

# Сброс пароля админки — Яндекс SMTP
# 1) 2FA: https://id.yandex.ru/security
# 2) Пароли приложений → Создать → «stopkek API» → SMTP_PASS
# https://id.yandex.ru/security/app-passwords
ADMIN_APP_URL=http://localhost:5173
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=stopkeksprt@yandex.ru
SMTP_PASS=
SMTP_FROM=stopkek Admin <stopkeksprt@yandex.ru>

# Верификация паспорта: автоподтверждение через N минут без ответа админа
IDENTITY_AUTO_APPROVE_MIN=5

# Замки (если не задано в админке → Настройки → Замки)
LOCK_HTTP_BASE_URL=
LOCK_HTTP_TOKEN=
LOCK_MQTT_TOPIC=stopkek/locks

# Push через Expo (https://expo.dev/notifications)
# В мобилке: EXPO_PUBLIC_EAS_PROJECT_ID из app.json / eas.json
