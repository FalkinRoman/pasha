{
  "name": "stopkek-kiosk",
  "version": "0.1.0",
  "private": true,
  "description": "Windows overlay для ПК клуба stopkek",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on http://127.0.0.1:5174 && electron .\"",
    "build": "vite build",
    "start": "electron .",
    "pack:win": "npm run build && electron-builder --win portable"
  },
  "dependencies": {
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/qrcode": "^1.5.5",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.1.2",
    "electron": "^35.1.2",
    "electron-builder": "^26.0.12",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "build": {
    "appId": "com.stopkek.kiosk",
    "productName": "stopkek Kiosk",
    "directories": { "output": "release" },
    "files": ["dist/**/*", "electron/**/*", "config.json"],
    "win": {
      "target": ["portable"]
    }
  }
}
