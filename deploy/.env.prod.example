# Скопируй: cp deploy/.env.prod.example deploy/.env.prod

# Публичный URL (без слэша в конце) — для админки и CORS
# До HTTPS — http; после init-ssl.sh — https
PUBLIC_BASE_URL=https://stopkek.site
PUBLIC_API_URL=https://stopkek.site/api
KIOSK_API_KEY=CHANGE_ME_KIOSK_SECRET
# В проде только per-seat ключи (HMAC по месту). Общий мастер-ключ как заголовок не принимается.
KIOSK_ALLOW_GLOBAL_KEY=false
HTTP_PORT=80
HTTPS_PORT=443

# Postgres (только внутри docker-сети + для DATABASE_URL в api)
POSTGRES_USER=stopkek
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=stopkek

# API (остальное — в env_file, монтируется в контейнер api)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE
JWT_ADMIN_SECRET=CHANGE_ME_ANOTHER_32_CHARS_ADMIN
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ADMIN_TTL=12h

ADMIN_APP_URL=https://stopkek.site
ADMIN_EMAIL=stopkeksprt@yandex.ru
ADMIN_PASSWORD=CHANGE_ME_ADMIN_LOGIN
ADMIN_NAME=Админ и поддержка
SUPPORT_EMAIL=stopkeksprt@yandex.ru

# SMS.ru — ОБЯЗАТЕЛЬНО для входа в мобилке в проде (без него вход не работает).
SMSRU_API_ID=
# В проде ДЕРЖАТЬ ПУСТЫМ. Любой код здесь = вход по этому коду без SMS (дыра).
MOCK_CALL_CODES=
# Apple App Review: фиксированный вход без звонка (только этот номер + код)
REVIEW_LOGIN_PHONE=+79001234567
REVIEW_LOGIN_CODE=1234
CALL_CODE_TTL_SEC=300
CALL_REQUEST_COOLDOWN_SEC=60

# Почта (сброс пароля админки)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=stopkeksprt@yandex.ru
SMTP_PASS=
SMTP_FROM=stopkek Admin <stopkeksprt@yandex.ru>

# CORS — админка + expo (добавь IP если тест без домена)
CORS_ORIGINS=https://stopkek.site,https://www.stopkek.site

# Замки (mock на старте)
LOCK_HTTP_BASE_URL=
LOCK_HTTP_TOKEN=

# YooKassa (опционально)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=stopkek://wallet/topup/success
# В проде false: иначе кошелёк пополняется бесплатно mock-запросом (дыра).
WALLET_MOCK_TOPUP=false

IDENTITY_AUTO_APPROVE_MIN=5
API_PREFIX=api
PORT=3001
