# Скопируй: cp deploy/.env.prod.example deploy/.env.prod

# Публичный URL (без слэша в конце) — для админки и CORS
PUBLIC_BASE_URL=https://stopkek.example.com
PUBLIC_API_URL=https://stopkek.example.com/api
KIOSK_API_KEY=CHANGE_ME_KIOSK_SECRET
HTTP_PORT=80

# Postgres (только внутри docker-сети + для DATABASE_URL в api)
POSTGRES_USER=stopkek
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=stopkek

# API (остальное — в env_file, монтируется в контейнер api)
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE
JWT_ADMIN_SECRET=CHANGE_ME_ANOTHER_32_CHARS_ADMIN
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
JWT_ADMIN_TTL=12h

ADMIN_APP_URL=https://stopkek.example.com
ADMIN_EMAIL=stopkeksprt@yandex.ru
ADMIN_PASSWORD=CHANGE_ME_ADMIN_LOGIN
ADMIN_NAME=Админ и поддержка
SUPPORT_EMAIL=stopkeksprt@yandex.ru

# SMS.ru — обязательно для входа в мобилке
SMSRU_API_ID=
MOCK_CALL_CODES=
CALL_CODE_TTL_SEC=300
CALL_REQUEST_COOLDOWN_SEC=60

# Почта (сброс пароля админки)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=stopkeksprt@yandex.ru
SMTP_PASS=
SMTP_FROM=stopkek Admin <stopkeksprt@yandex.ru>

# CORS — админка + expo (добавь IP если тест без домена)
CORS_ORIGINS=https://stopkek.example.com

# Замки (mock на старте)
LOCK_HTTP_BASE_URL=
LOCK_HTTP_TOKEN=

# YooKassa (опционально)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=stopkek://wallet/topup/success
WALLET_MOCK_TOPUP=true

IDENTITY_AUTO_APPROVE_MIN=5
API_PREFIX=api
PORT=3001
